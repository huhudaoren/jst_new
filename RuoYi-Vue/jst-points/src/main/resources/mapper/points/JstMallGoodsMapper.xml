<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.points.mapper.JstMallGoodsMapper">
    
    <resultMap type="JstMallGoods" id="JstMallGoodsResult">
        <result property="goodsId"    column="goods_id"    />
        <result property="goodsName"    column="goods_name"    />
        <result property="goodsType"    column="goods_type"    />
        <result property="coverImage"    column="cover_image"    />
        <result property="description"    column="description"    />
        <result property="pointsPrice"    column="points_price"    />
        <result property="cashPrice"    column="cash_price"    />
        <result property="stock"    column="stock"    />
        <result property="stockWarning"    column="stock_warning"    />
        <result property="roleLimit"    column="role_limit"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstMallGoodsVo">
        select goods_id, goods_name, goods_type, cover_image, description, points_price, cash_price, stock, stock_warning, role_limit, status, create_by, create_time, update_by, update_time, remark, del_flag from jst_mall_goods
    </sql>

    <select id="selectJstMallGoodsList" parameterType="JstMallGoods" resultMap="JstMallGoodsResult">
        <include refid="selectJstMallGoodsVo"/>
        <where>  
            <if test="goodsName != null  and goodsName != ''"> and goods_name like concat('%', #{goodsName}, '%')</if>
            <if test="goodsType != null  and goodsType != ''"> and goods_type = #{goodsType}</if>
            <if test="coverImage != null  and coverImage != ''"> and cover_image = #{coverImage}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="pointsPrice != null "> and points_price = #{pointsPrice}</if>
            <if test="cashPrice != null "> and cash_price = #{cashPrice}</if>
            <if test="stock != null "> and stock = #{stock}</if>
            <if test="stockWarning != null "> and stock_warning = #{stockWarning}</if>
            <if test="roleLimit != null  and roleLimit != ''"> and role_limit = #{roleLimit}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstMallGoodsByGoodsId" parameterType="Long" resultMap="JstMallGoodsResult">
        <include refid="selectJstMallGoodsVo"/>
        where goods_id = #{goodsId}
    </select>

    <insert id="insertJstMallGoods" parameterType="JstMallGoods" useGeneratedKeys="true" keyProperty="goodsId">
        insert into jst_mall_goods
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="goodsName != null and goodsName != ''">goods_name,</if>
            <if test="goodsType != null and goodsType != ''">goods_type,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="description != null">description,</if>
            <if test="pointsPrice != null">points_price,</if>
            <if test="cashPrice != null">cash_price,</if>
            <if test="stock != null">stock,</if>
            <if test="stockWarning != null">stock_warning,</if>
            <if test="roleLimit != null">role_limit,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="goodsName != null and goodsName != ''">#{goodsName},</if>
            <if test="goodsType != null and goodsType != ''">#{goodsType},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="description != null">#{description},</if>
            <if test="pointsPrice != null">#{pointsPrice},</if>
            <if test="cashPrice != null">#{cashPrice},</if>
            <if test="stock != null">#{stock},</if>
            <if test="stockWarning != null">#{stockWarning},</if>
            <if test="roleLimit != null">#{roleLimit},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstMallGoods" parameterType="JstMallGoods">
        update jst_mall_goods
        <trim prefix="SET" suffixOverrides=",">
            <if test="goodsName != null and goodsName != ''">goods_name = #{goodsName},</if>
            <if test="goodsType != null and goodsType != ''">goods_type = #{goodsType},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="description != null">description = #{description},</if>
            <if test="pointsPrice != null">points_price = #{pointsPrice},</if>
            <if test="cashPrice != null">cash_price = #{cashPrice},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="stockWarning != null">stock_warning = #{stockWarning},</if>
            <if test="roleLimit != null">role_limit = #{roleLimit},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where goods_id = #{goodsId}
    </update>

    <delete id="deleteJstMallGoodsByGoodsId" parameterType="Long">
        delete from jst_mall_goods where goods_id = #{goodsId}
    </delete>

    <delete id="deleteJstMallGoodsByGoodsIds" parameterType="String">
        delete from jst_mall_goods where goods_id in 
        <foreach item="goodsId" collection="array" open="(" separator="," close=")">
            #{goodsId}
        </foreach>
    </delete>
</mapper>