<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.points.mapper.JstMallExchangeOrderMapper">
    
    <resultMap type="JstMallExchangeOrder" id="JstMallExchangeOrderResult">
        <result property="exchangeId"    column="exchange_id"    />
        <result property="exchangeNo"    column="exchange_no"    />
        <result property="userId"    column="user_id"    />
        <result property="goodsId"    column="goods_id"    />
        <result property="quantity"    column="quantity"    />
        <result property="pointsUsed"    column="points_used"    />
        <result property="cashAmount"    column="cash_amount"    />
        <result property="orderId"    column="order_id"    />
        <result property="addressSnapshotJson"    column="address_snapshot_json"    />
        <result property="status"    column="status"    />
        <result property="logisticsCompany"    column="logistics_company"    />
        <result property="logisticsNo"    column="logistics_no"    />
        <result property="shipTime"    column="ship_time"    />
        <result property="completeTime"    column="complete_time"    />
        <result property="aftersaleStatus"    column="aftersale_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="userName"    column="user_name_"    />
        <result property="goodsName"    column="goods_name_"    />
    </resultMap>

    <sql id="selectJstMallExchangeOrderVo">
        select t.*,
               u.nick_name as user_name_,
               g.goods_name as goods_name_
        from jst_mall_exchange_order t
        left join sys_user u on t.user_id = u.user_id and u.del_flag = '0'
        left join jst_mall_goods g on t.goods_id = g.goods_id and g.del_flag = '0'
    </sql>

    <select id="selectJstMallExchangeOrderList" parameterType="JstMallExchangeOrder" resultMap="JstMallExchangeOrderResult">
        <include refid="selectJstMallExchangeOrderVo"/>
        <where>
            <if test="exchangeNo != null  and exchangeNo != ''"> and t.exchange_no = #{exchangeNo}</if>
            <if test="userId != null "> and t.user_id = #{userId}</if>
            <if test="goodsId != null "> and t.goods_id = #{goodsId}</if>
            <if test="quantity != null "> and t.quantity = #{quantity}</if>
            <if test="pointsUsed != null "> and t.points_used = #{pointsUsed}</if>
            <if test="cashAmount != null "> and t.cash_amount = #{cashAmount}</if>
            <if test="orderId != null "> and t.order_id = #{orderId}</if>
            <if test="addressSnapshotJson != null  and addressSnapshotJson != ''"> and t.address_snapshot_json = #{addressSnapshotJson}</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
            <if test="logisticsCompany != null  and logisticsCompany != ''"> and t.logistics_company = #{logisticsCompany}</if>
            <if test="logisticsNo != null  and logisticsNo != ''"> and t.logistics_no = #{logisticsNo}</if>
            <if test="shipTime != null "> and t.ship_time = #{shipTime}</if>
            <if test="completeTime != null "> and t.complete_time = #{completeTime}</if>
            <if test="aftersaleStatus != null  and aftersaleStatus != ''"> and t.aftersale_status = #{aftersaleStatus}</if>
        </where>
    </select>
    
    <select id="selectJstMallExchangeOrderByExchangeId" parameterType="Long" resultMap="JstMallExchangeOrderResult">
        <include refid="selectJstMallExchangeOrderVo"/>
        where t.exchange_id = #{exchangeId}
    </select>

    <insert id="insertJstMallExchangeOrder" parameterType="JstMallExchangeOrder" useGeneratedKeys="true" keyProperty="exchangeId">
        insert into jst_mall_exchange_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="exchangeNo != null and exchangeNo != ''">exchange_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="quantity != null">quantity,</if>
            <if test="pointsUsed != null">points_used,</if>
            <if test="cashAmount != null">cash_amount,</if>
            <if test="orderId != null">order_id,</if>
            <if test="addressSnapshotJson != null and addressSnapshotJson != ''">address_snapshot_json,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="logisticsCompany != null">logistics_company,</if>
            <if test="logisticsNo != null">logistics_no,</if>
            <if test="shipTime != null">ship_time,</if>
            <if test="completeTime != null">complete_time,</if>
            <if test="aftersaleStatus != null">aftersale_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="exchangeNo != null and exchangeNo != ''">#{exchangeNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="pointsUsed != null">#{pointsUsed},</if>
            <if test="cashAmount != null">#{cashAmount},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="addressSnapshotJson != null and addressSnapshotJson != ''">#{addressSnapshotJson},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="logisticsCompany != null">#{logisticsCompany},</if>
            <if test="logisticsNo != null">#{logisticsNo},</if>
            <if test="shipTime != null">#{shipTime},</if>
            <if test="completeTime != null">#{completeTime},</if>
            <if test="aftersaleStatus != null">#{aftersaleStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstMallExchangeOrder" parameterType="JstMallExchangeOrder">
        update jst_mall_exchange_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="exchangeNo != null and exchangeNo != ''">exchange_no = #{exchangeNo},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="goodsId != null">goods_id = #{goodsId},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="pointsUsed != null">points_used = #{pointsUsed},</if>
            <if test="cashAmount != null">cash_amount = #{cashAmount},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="addressSnapshotJson != null and addressSnapshotJson != ''">address_snapshot_json = #{addressSnapshotJson},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="logisticsCompany != null">logistics_company = #{logisticsCompany},</if>
            <if test="logisticsNo != null">logistics_no = #{logisticsNo},</if>
            <if test="shipTime != null">ship_time = #{shipTime},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
            <if test="aftersaleStatus != null">aftersale_status = #{aftersaleStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where exchange_id = #{exchangeId}
    </update>

    <delete id="deleteJstMallExchangeOrderByExchangeId" parameterType="Long">
        delete from jst_mall_exchange_order where exchange_id = #{exchangeId}
    </delete>

    <delete id="deleteJstMallExchangeOrderByExchangeIds" parameterType="String">
        delete from jst_mall_exchange_order where exchange_id in 
        <foreach item="exchangeId" collection="array" open="(" separator="," close=")">
            #{exchangeId}
        </foreach>
    </delete>
</mapper>