            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="createdUserId != null "> and created_user_id = #{createdUserId}</if>
        </where>
    </select>
    
    <select id="selectJstContestByContestId" parameterType="Long" resultMap="JstContestResult">
        <include refid="selectJstContestVo"/>
        where contest_id = #{contestId}
