            <if test="enrollEndTime != null "> and enroll_end_time = #{enrollEndTime}</if>
            <if test="eventStartTime != null "> and event_start_time = #{eventStartTime}</if>
            <if test="eventEndTime != null "> and event_end_time = #{eventEndTime}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="supportChannelEnroll != null "> and support_channel_enroll = #{supportChannelEnroll}</if>
            <if test="supportPointsDeduct != null "> and support_points_deduct = #{supportPointsDeduct}</if>
            <if test="supportAppointment != null "> and support_appointment = #{supportAppointment}</if>
            <if test="certRuleJson != null  and certRuleJson != ''"> and cert_rule_json = #{certRuleJson}</if>
            <if test="scoreRuleJson != null  and scoreRuleJson != ''"> and score_rule_json = #{scoreRuleJson}</if>
            <if test="formTemplateId != null "> and form_template_id = #{formTemplateId}</if>
