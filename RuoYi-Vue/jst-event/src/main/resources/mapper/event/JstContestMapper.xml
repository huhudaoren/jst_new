    <sql id="selectJstContestVo">
        select contest_id, contest_name, source_type, partner_id, category, group_levels, cover_image, description, enroll_start_time, enroll_end_time, event_start_time, event_end_time, price, support_channel_enroll, support_points_deduct, support_appointment, cert_rule_json, score_rule_json, form_template_id, aftersale_days, audit_status, status, created_user_id, create_by, create_time, update_by, update_time, remark, del_flag from jst_contest
    </sql>

    <select id="selectJstContestList" parameterType="JstContest" resultMap="JstContestResult">
        <include refid="selectJstContestVo"/>
        <where>  
            <if test="contestName != null  and contestName != ''"> and contest_name like concat('%', #{contestName}, '%')</if>
            <if test="sourceType != null  and sourceType != ''"> and source_type = #{sourceType}</if>
            <if test="partnerId != null "> and partner_id = #{partnerId}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="groupLevels != null  and groupLevels != ''"> and group_levels = #{groupLevels}</if>
