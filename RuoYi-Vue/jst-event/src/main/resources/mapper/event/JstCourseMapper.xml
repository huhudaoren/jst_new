<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.event.mapper.JstCourseMapper">
    
    <resultMap type="JstCourse" id="JstCourseResult">
        <result property="courseId"    column="course_id"    />
        <result property="courseName"    column="course_name"    />
        <result property="courseType"    column="course_type"    />
        <result property="coverImage"    column="cover_image"    />
        <result property="description"    column="description"    />
        <result property="price"    column="price"    />
        <result property="pointsPrice"    column="points_price"    />
        <result property="creatorType"    column="creator_type"    />
        <result property="creatorId"    column="creator_id"    />
        <result property="maicSourceId"    column="maic_source_id"    />
        <result property="auditStatus"    column="audit_status"    />
        <result property="status"    column="status"    />
        <result property="visibleScope"    column="visible_scope"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstCourseVo">
        select course_id, course_name, course_type, cover_image, description, price, points_price, creator_type, creator_id, maic_source_id, audit_status, status, visible_scope, create_by, create_time, update_by, update_time, remark, del_flag from jst_course
    </sql>

    <select id="selectJstCourseList" parameterType="JstCourse" resultMap="JstCourseResult">
        <include refid="selectJstCourseVo"/>
        <where>  
            <if test="courseName != null  and courseName != ''"> and course_name like concat('%', #{courseName}, '%')</if>
            <if test="courseType != null  and courseType != ''"> and course_type = #{courseType}</if>
            <if test="coverImage != null  and coverImage != ''"> and cover_image = #{coverImage}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="pointsPrice != null "> and points_price = #{pointsPrice}</if>
            <if test="creatorType != null  and creatorType != ''"> and creator_type = #{creatorType}</if>
            <if test="creatorId != null "> and creator_id = #{creatorId}</if>
            <if test="maicSourceId != null  and maicSourceId != ''"> and maic_source_id = #{maicSourceId}</if>
            <if test="auditStatus != null  and auditStatus != ''"> and audit_status = #{auditStatus}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="visibleScope != null  and visibleScope != ''"> and visible_scope = #{visibleScope}</if>
        </where>
    </select>
    
    <select id="selectJstCourseByCourseId" parameterType="Long" resultMap="JstCourseResult">
        <include refid="selectJstCourseVo"/>
        where course_id = #{courseId}
    </select>

    <insert id="insertJstCourse" parameterType="JstCourse" useGeneratedKeys="true" keyProperty="courseId">
        insert into jst_course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name,</if>
            <if test="courseType != null and courseType != ''">course_type,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="description != null">description,</if>
            <if test="price != null">price,</if>
            <if test="pointsPrice != null">points_price,</if>
            <if test="creatorType != null and creatorType != ''">creator_type,</if>
            <if test="creatorId != null">creator_id,</if>
            <if test="maicSourceId != null">maic_source_id,</if>
            <if test="auditStatus != null and auditStatus != ''">audit_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="visibleScope != null">visible_scope,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">#{courseName},</if>
            <if test="courseType != null and courseType != ''">#{courseType},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="description != null">#{description},</if>
            <if test="price != null">#{price},</if>
            <if test="pointsPrice != null">#{pointsPrice},</if>
            <if test="creatorType != null and creatorType != ''">#{creatorType},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="maicSourceId != null">#{maicSourceId},</if>
            <if test="auditStatus != null and auditStatus != ''">#{auditStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="visibleScope != null">#{visibleScope},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstCourse" parameterType="JstCourse">
        update jst_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name = #{courseName},</if>
            <if test="courseType != null and courseType != ''">course_type = #{courseType},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="description != null">description = #{description},</if>
            <if test="price != null">price = #{price},</if>
            <if test="pointsPrice != null">points_price = #{pointsPrice},</if>
            <if test="creatorType != null and creatorType != ''">creator_type = #{creatorType},</if>
            <if test="creatorId != null">creator_id = #{creatorId},</if>
            <if test="maicSourceId != null">maic_source_id = #{maicSourceId},</if>
            <if test="auditStatus != null and auditStatus != ''">audit_status = #{auditStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="visibleScope != null">visible_scope = #{visibleScope},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where course_id = #{courseId}
    </update>

    <delete id="deleteJstCourseByCourseId" parameterType="Long">
        delete from jst_course where course_id = #{courseId}
    </delete>

    <delete id="deleteJstCourseByCourseIds" parameterType="String">
        delete from jst_course where course_id in 
        <foreach item="courseId" collection="array" open="(" separator="," close=")">
            #{courseId}
        </foreach>
    </delete>
</mapper>