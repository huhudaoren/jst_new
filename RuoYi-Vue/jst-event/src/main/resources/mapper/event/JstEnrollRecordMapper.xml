        <result property="contestId"    column="contest_id"    />
        <result property="userId"    column="user_id"    />
        <result property="participantId"    column="participant_id"    />
        <result property="channelId"    column="channel_id"    />
        <result property="enrollSource"    column="enroll_source"    />
        <result property="templateId"    column="template_id"    />
        <result property="templateVersion"    column="template_version"    />
        <result property="formSnapshotJson"    column="form_snapshot_json"    />
        <result property="orderId"    column="order_id"    />
        <result property="materialStatus"    column="material_status"    />
        <result property="auditStatus"    column="audit_status"    />
        <result property="auditRemark"    column="audit_remark"    />
