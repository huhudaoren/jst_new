    <delete id="deleteJstEnrollRecordByEnrollId" parameterType="Long">
        delete from jst_enroll_record where enroll_id = #{enrollId}
    </delete>

    <delete id="deleteJstEnrollRecordByEnrollIds" parameterType="String">
        delete from jst_enroll_record where enroll_id in 
        <foreach item="enrollId" collection="array" open="(" separator="," close=")">
            #{enrollId}
        </foreach>
    </delete>
</mapper>
