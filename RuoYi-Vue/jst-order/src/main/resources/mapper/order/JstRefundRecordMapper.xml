<mapper namespace="com.ruoyi.jst.order.mapper.JstRefundRecordMapper">
    
    <resultMap type="JstRefundRecord" id="JstRefundRecordResult">
        <result property="refundId"    column="refund_id"    />
        <result property="refundNo"    column="refund_no"    />
        <result property="orderId"    column="order_id"    />
        <result property="itemId"    column="item_id"    />
        <result property="refundType"    column="refund_type"    />
        <result property="applySource"    column="apply_source"    />
        <result property="reason"    column="reason"    />
        <result property="applyCash"    column="apply_cash"    />
        <result property="applyPoints"    column="apply_points"    />
        <result property="actualCash"    column="actual_cash"    />
        <result property="actualPoints"    column="actual_points"    />
        <result property="couponReturned"    column="coupon_returned"    />
        <result property="status"    column="status"    />
        <result property="auditRemark"    column="audit_remark"    />
        <result property="operatorId"    column="operator_id"    />
