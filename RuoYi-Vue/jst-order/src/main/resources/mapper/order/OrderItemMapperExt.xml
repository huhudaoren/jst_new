<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.order.mapper.OrderItemMapperExt">

    <resultMap id="OrderItemResult" type="com.ruoyi.jst.order.domain.JstOrderItem">
        <result property="itemId" column="item_id"/>
        <result property="orderId" column="order_id"/>
        <result property="skuType" column="sku_type"/>
        <result property="refId" column="ref_id"/>
        <result property="itemName" column="item_name"/>
        <result property="quantity" column="quantity"/>
        <result property="listAmount" column="list_amount"/>
        <result property="couponShare" column="coupon_share"/>
        <result property="pointsShare" column="points_share"/>
        <result property="netPayShare" column="net_pay_share"/>
        <result property="serviceFeeShare" column="service_fee_share"/>
        <result property="rebateShare" column="rebate_share"/>
        <result property="refundAmount" column="refund_amount"/>
        <result property="refundPoints" column="refund_points"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <select id="selectByOrderId" resultMap="OrderItemResult">
        select *
        from jst_order_item
        where order_id = #{orderId}
          and del_flag = '0'
        order by item_id asc
    </select>
</mapper>
