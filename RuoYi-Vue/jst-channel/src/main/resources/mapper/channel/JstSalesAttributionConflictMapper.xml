<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.channel.mapper.JstSalesAttributionConflictMapper">

    <resultMap type="com.ruoyi.jst.channel.domain.JstSalesAttributionConflict" id="JstSalesAttributionConflictResult">
        <id     property="conflictId"        column="conflict_id"/>
        <result property="channelId"         column="channel_id"/>
        <result property="candidateSalesIds" column="candidate_sales_ids"/>
        <result property="reason"            column="reason"/>
        <result property="status"            column="status"/>
        <result property="resolvedBy"        column="resolved_by"/>
        <result property="resolvedAt"        column="resolved_at"/>
        <result property="resolutionRemark"  column="resolution_remark"/>
        <result property="createTime"        column="create_time"/>
        <result property="updateBy"          column="update_by"/>
        <result property="updateTime"        column="update_time"/>
    </resultMap>

    <resultMap type="com.ruoyi.jst.channel.domain.JstSalesAttributionConflict" id="JstSalesAttributionConflictListResult" extends="JstSalesAttributionConflictResult">
        <result property="channelName" column="channel_name_join"/>
    </resultMap>

    <sql id="cols">
        conflict_id, channel_id, candidate_sales_ids, reason, status,
        resolved_by, resolved_at, resolution_remark, create_time, update_by, update_time
    </sql>

    <select id="selectJstSalesAttributionConflictByConflictId" parameterType="Long" resultMap="JstSalesAttributionConflictResult">
        SELECT <include refid="cols"/> FROM jst_sales_attribution_conflict WHERE conflict_id = #{conflictId}
    </select>

    <select id="selectJstSalesAttributionConflictList" parameterType="com.ruoyi.jst.channel.domain.JstSalesAttributionConflict" resultMap="JstSalesAttributionConflictListResult">
        SELECT f.*,
               ch.channel_name AS channel_name_join
          FROM jst_sales_attribution_conflict f
          LEFT JOIN jst_channel ch ON f.channel_id = ch.channel_id AND ch.del_flag = '0'
        <where>
            <if test="channelId != null">AND f.channel_id = #{channelId}</if>
            <if test="status != null and status != ''">AND f.status = #{status}</if>
        </where>
        ORDER BY f.create_time DESC
    </select>

    <insert id="insertJstSalesAttributionConflict" parameterType="com.ruoyi.jst.channel.domain.JstSalesAttributionConflict">
        INSERT INTO jst_sales_attribution_conflict (
            conflict_id, channel_id, candidate_sales_ids, reason, status,
            resolved_by, resolved_at, resolution_remark, create_time
        ) VALUES (
            #{conflictId}, #{channelId}, #{candidateSalesIds}, #{reason}, #{status},
            #{resolvedBy}, #{resolvedAt}, #{resolutionRemark}, NOW()
        )
    </insert>

    <update id="updateJstSalesAttributionConflict" parameterType="com.ruoyi.jst.channel.domain.JstSalesAttributionConflict">
        UPDATE jst_sales_attribution_conflict
        <set>
            <if test="channelId != null">channel_id = #{channelId},</if>
            <if test="candidateSalesIds != null">candidate_sales_ids = #{candidateSalesIds},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="resolvedBy != null">resolved_by = #{resolvedBy},</if>
            <if test="resolvedAt != null">resolved_at = #{resolvedAt},</if>
            <if test="resolutionRemark != null">resolution_remark = #{resolutionRemark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = NOW()
        </set>
        WHERE conflict_id = #{conflictId}
    </update>

    <delete id="deleteJstSalesAttributionConflictByConflictId" parameterType="Long">
        DELETE FROM jst_sales_attribution_conflict WHERE conflict_id = #{conflictId}
    </delete>

    <select id="selectByStatus" resultMap="JstSalesAttributionConflictListResult">
        SELECT f.*,
               ch.channel_name AS channel_name_join
          FROM jst_sales_attribution_conflict f
          LEFT JOIN jst_channel ch ON f.channel_id = ch.channel_id AND ch.del_flag = '0'
        <where>
            <if test="status != null and status != ''">AND f.status = #{status}</if>
        </where>
        ORDER BY f.create_time DESC
    </select>

</mapper>
