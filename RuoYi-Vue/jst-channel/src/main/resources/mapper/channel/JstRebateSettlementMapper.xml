<mapper namespace="com.ruoyi.jst.channel.mapper.JstRebateSettlementMapper">
    
    <resultMap type="JstRebateSettlement" id="JstRebateSettlementResult">
        <result property="settlementId"    column="settlement_id"    />
        <result property="settlementNo"    column="settlement_no"    />
        <result property="channelId"    column="channel_id"    />
        <result property="applyAmount"    column="apply_amount"    />
        <result property="negativeOffsetAmount"    column="negative_offset_amount"    />
        <result property="actualPayAmount"    column="actual_pay_amount"    />
        <result property="invoiceStatus"    column="invoice_status"    />
        <result property="invoiceId"    column="invoice_id"    />
        <result property="bankAccountSnapshot"    column="bank_account_snapshot"    />
        <result property="status"    column="status"    />
        <result property="auditRemark"    column="audit_remark"    />
        <result property="payVoucherUrl"    column="pay_voucher_url"    />
        <result property="applyTime"    column="apply_time"    />
        <result property="payTime"    column="pay_time"    />
        <result property="createBy"    column="create_by"    />
