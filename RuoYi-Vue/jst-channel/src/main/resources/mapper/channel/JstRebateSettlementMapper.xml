        <result property="delFlag"    column="del_flag"    />
        <result property="channelName"    column="channel_name_"    />
    </resultMap>

    <sql id="selectJstRebateSettlementVo">
        select t.*,
               ch.channel_name as channel_name_
        from jst_rebate_settlement t
        left join jst_channel ch on t.channel_id = ch.channel_id and ch.del_flag = '0'
    </sql>

    <select id="selectJstRebateSettlementList" parameterType="JstRebateSettlement" resultMap="JstRebateSettlementResult">
        <include refid="selectJstRebateSettlementVo"/>
        <where>
            <if test="settlementNo != null  and settlementNo != ''"> and t.settlement_no = #{settlementNo}</if>
            <if test="channelId != null "> and t.channel_id = #{channelId}</if>
            <if test="applyAmount != null "> and t.apply_amount = #{applyAmount}</if>
            <if test="negativeOffsetAmount != null "> and t.negative_offset_amount = #{negativeOffsetAmount}</if>
            <if test="actualPayAmount != null "> and t.actual_pay_amount = #{actualPayAmount}</if>
            <if test="invoiceStatus != null  and invoiceStatus != ''"> and t.invoice_status = #{invoiceStatus}</if>
            <if test="invoiceId != null "> and t.invoice_id = #{invoiceId}</if>
            <if test="bankAccountSnapshot != null  and bankAccountSnapshot != ''"> and t.bank_account_snapshot = #{bankAccountSnapshot}</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
            <if test="auditRemark != null  and auditRemark != ''"> and t.audit_remark = #{auditRemark}</if>
            <if test="payVoucherUrl != null  and payVoucherUrl != ''"> and t.pay_voucher_url = #{payVoucherUrl}</if>
            <if test="applyTime != null "> and t.apply_time = #{applyTime}</if>
            <if test="payTime != null "> and t.pay_time = #{payTime}</if>
        </where>
    </select>
    
    <select id="selectJstRebateSettlementBySettlementId" parameterType="Long" resultMap="JstRebateSettlementResult">
        <include refid="selectJstRebateSettlementVo"/>
        where t.settlement_id = #{settlementId}
    </select>

    <insert id="insertJstRebateSettlement" parameterType="JstRebateSettlement" useGeneratedKeys="true" keyProperty="settlementId">
        insert into jst_rebate_settlement
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="settlementNo != null and settlementNo != ''">settlement_no,</if>
            <if test="channelId != null">channel_id,</if>
            <if test="applyAmount != null">apply_amount,</if>
            <if test="negativeOffsetAmount != null">negative_offset_amount,</if>
            <if test="actualPayAmount != null">actual_pay_amount,</if>
            <if test="invoiceStatus != null and invoiceStatus != ''">invoice_status,</if>
            <if test="invoiceId != null">invoice_id,</if>
            <if test="bankAccountSnapshot != null">bank_account_snapshot,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="auditRemark != null">audit_remark,</if>
            <if test="payVoucherUrl != null">pay_voucher_url,</if>
            <if test="applyTime != null">apply_time,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="settlementNo != null and settlementNo != ''">#{settlementNo},</if>
            <if test="channelId != null">#{channelId},</if>
            <if test="applyAmount != null">#{applyAmount},</if>
            <if test="negativeOffsetAmount != null">#{negativeOffsetAmount},</if>
            <if test="actualPayAmount != null">#{actualPayAmount},</if>
            <if test="invoiceStatus != null and invoiceStatus != ''">#{invoiceStatus},</if>
            <if test="invoiceId != null">#{invoiceId},</if>
            <if test="bankAccountSnapshot != null">#{bankAccountSnapshot},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="auditRemark != null">#{auditRemark},</if>
            <if test="payVoucherUrl != null">#{payVoucherUrl},</if>
            <if test="applyTime != null">#{applyTime},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstRebateSettlement" parameterType="JstRebateSettlement">
        update jst_rebate_settlement
        <trim prefix="SET" suffixOverrides=",">
            <if test="settlementNo != null and settlementNo != ''">settlement_no = #{settlementNo},</if>
            <if test="channelId != null">channel_id = #{channelId},</if>
            <if test="applyAmount != null">apply_amount = #{applyAmount},</if>
            <if test="negativeOffsetAmount != null">negative_offset_amount = #{negativeOffsetAmount},</if>
            <if test="actualPayAmount != null">actual_pay_amount = #{actualPayAmount},</if>
            <if test="invoiceStatus != null and invoiceStatus != ''">invoice_status = #{invoiceStatus},</if>
            <if test="invoiceId != null">invoice_id = #{invoiceId},</if>
            <if test="bankAccountSnapshot != null">bank_account_snapshot = #{bankAccountSnapshot},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="payVoucherUrl != null">pay_voucher_url = #{payVoucherUrl},</if>
            <if test="applyTime != null">apply_time = #{applyTime},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where settlement_id = #{settlementId}
    </update>

    <delete id="deleteJstRebateSettlementBySettlementId" parameterType="Long">
        delete from jst_rebate_settlement where settlement_id = #{settlementId}
    </delete>

    <delete id="deleteJstRebateSettlementBySettlementIds" parameterType="String">
        delete from jst_rebate_settlement where settlement_id in 
        <foreach item="settlementId" collection="array" open="(" separator="," close=")">
            #{settlementId}
        </foreach>
    </delete>
</mapper>