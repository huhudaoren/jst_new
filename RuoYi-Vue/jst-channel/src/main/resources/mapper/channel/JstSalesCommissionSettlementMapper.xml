<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.channel.mapper.JstSalesCommissionSettlementMapper">

    <resultMap type="com.ruoyi.jst.channel.domain.JstSalesCommissionSettlement" id="JstSalesCommissionSettlementResult">
        <id     property="settlementId"  column="settlement_id"/>
        <result property="salesId"       column="sales_id"/>
        <result property="period"        column="period"/>
        <result property="totalCount"    column="total_count"/>
        <result property="totalAmount"   column="total_amount"/>
        <result property="status"        column="status"/>
        <result property="approvedBy"    column="approved_by"/>
        <result property="approvedAt"    column="approved_at"/>
        <result property="paidAt"        column="paid_at"/>
        <result property="payVoucher"    column="pay_voucher"/>
        <result property="rejectReason"  column="reject_reason"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateBy"      column="update_by"/>
        <result property="updateTime"    column="update_time"/>
    </resultMap>

    <sql id="cols">
        settlement_id, sales_id, period, total_count, total_amount, status,
        approved_by, approved_at, paid_at, pay_voucher, reject_reason,
        create_time, update_by, update_time
    </sql>

    <select id="selectJstSalesCommissionSettlementBySettlementId" parameterType="Long" resultMap="JstSalesCommissionSettlementResult">
        SELECT <include refid="cols"/> FROM jst_sales_commission_settlement WHERE settlement_id = #{settlementId}
    </select>

    <select id="selectJstSalesCommissionSettlementList" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionSettlement" resultMap="JstSalesCommissionSettlementResult">
        SELECT <include refid="cols"/> FROM jst_sales_commission_settlement
        <where>
            <if test="salesId != null">AND sales_id = #{salesId}</if>
            <if test="period != null and period != ''">AND period = #{period}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY period DESC
    </select>

    <insert id="insertJstSalesCommissionSettlement" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionSettlement">
        INSERT INTO jst_sales_commission_settlement (
            settlement_id, sales_id, period, total_count, total_amount, status,
            approved_by, approved_at, paid_at, pay_voucher, reject_reason, create_time
        ) VALUES (
            #{settlementId}, #{salesId}, #{period}, #{totalCount}, #{totalAmount}, #{status},
            #{approvedBy}, #{approvedAt}, #{paidAt}, #{payVoucher}, #{rejectReason}, NOW()
        )
    </insert>

    <update id="updateJstSalesCommissionSettlement" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionSettlement">
        UPDATE jst_sales_commission_settlement
        <set>
            <if test="salesId != null">sales_id = #{salesId},</if>
            <if test="period != null">period = #{period},</if>
            <if test="totalCount != null">total_count = #{totalCount},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="approvedBy != null">approved_by = #{approvedBy},</if>
            <if test="approvedAt != null">approved_at = #{approvedAt},</if>
            <if test="paidAt != null">paid_at = #{paidAt},</if>
            <if test="payVoucher != null">pay_voucher = #{payVoucher},</if>
            <if test="rejectReason != null">reject_reason = #{rejectReason},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = NOW()
        </set>
        WHERE settlement_id = #{settlementId}
    </update>

    <delete id="deleteJstSalesCommissionSettlementBySettlementId" parameterType="Long">
        DELETE FROM jst_sales_commission_settlement WHERE settlement_id = #{settlementId}
    </delete>

</mapper>
