<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.channel.mapper.JstSalesCommissionLedgerMapper">

    <resultMap type="com.ruoyi.jst.channel.domain.JstSalesCommissionLedger" id="JstSalesCommissionLedgerResult">
        <id     property="ledgerId"      column="ledger_id"/>
        <result property="salesId"       column="sales_id"/>
        <result property="orderId"       column="order_id"/>
        <result property="orderNo"       column="order_no"/>
        <result property="channelId"     column="channel_id"/>
        <result property="bindingType"   column="binding_type"/>
        <result property="businessType"  column="business_type"/>
        <result property="baseAmount"    column="base_amount"/>
        <result property="appliedRate"   column="applied_rate"/>
        <result property="rawAmount"     column="raw_amount"/>
        <result property="compressRatio" column="compress_ratio"/>
        <result property="amount"        column="amount"/>
        <result property="status"        column="status"/>
        <result property="accrueAt"      column="accrue_at"/>
        <result property="accruedAt"     column="accrued_at"/>
        <result property="settlementId"  column="settlement_id"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateTime"    column="update_time"/>
    </resultMap>

    <sql id="cols">
        ledger_id, sales_id, order_id, order_no, channel_id, binding_type, business_type,
        base_amount, applied_rate, raw_amount, compress_ratio, amount, status,
        accrue_at, accrued_at, settlement_id, create_time, update_time
    </sql>

    <select id="selectJstSalesCommissionLedgerByLedgerId" parameterType="Long" resultMap="JstSalesCommissionLedgerResult">
        SELECT <include refid="cols"/> FROM jst_sales_commission_ledger WHERE ledger_id = #{ledgerId}
    </select>

    <select id="selectJstSalesCommissionLedgerList" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionLedger" resultMap="JstSalesCommissionLedgerResult">
        SELECT <include refid="cols"/> FROM jst_sales_commission_ledger
        <where>
            <if test="salesId != null">AND sales_id = #{salesId}</if>
            <if test="channelId != null">AND channel_id = #{channelId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
            <if test="settlementId != null">AND settlement_id = #{settlementId}</if>
            <if test="businessType != null and businessType != ''">AND business_type = #{businessType}</if>
        </where>
        ORDER BY create_time DESC
    </select>

    <insert id="insertJstSalesCommissionLedger" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionLedger">
        INSERT INTO jst_sales_commission_ledger (
            ledger_id, sales_id, order_id, order_no, channel_id, binding_type, business_type,
            base_amount, applied_rate, raw_amount, compress_ratio, amount, status,
            accrue_at, accrued_at, settlement_id, create_time
        ) VALUES (
            #{ledgerId}, #{salesId}, #{orderId}, #{orderNo}, #{channelId}, #{bindingType},
            #{businessType}, #{baseAmount}, #{appliedRate}, #{rawAmount}, #{compressRatio},
            #{amount}, #{status}, #{accrueAt}, #{accruedAt}, #{settlementId}, NOW()
        )
    </insert>

    <update id="updateJstSalesCommissionLedger" parameterType="com.ruoyi.jst.channel.domain.JstSalesCommissionLedger">
        UPDATE jst_sales_commission_ledger
        <set>
            <if test="salesId != null">sales_id = #{salesId},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="orderNo != null">order_no = #{orderNo},</if>
            <if test="channelId != null">channel_id = #{channelId},</if>
            <if test="bindingType != null">binding_type = #{bindingType},</if>
            <if test="businessType != null">business_type = #{businessType},</if>
            <if test="baseAmount != null">base_amount = #{baseAmount},</if>
            <if test="appliedRate != null">applied_rate = #{appliedRate},</if>
            <if test="rawAmount != null">raw_amount = #{rawAmount},</if>
            <if test="compressRatio != null">compress_ratio = #{compressRatio},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="accrueAt != null">accrue_at = #{accrueAt},</if>
            <if test="accruedAt != null">accrued_at = #{accruedAt},</if>
            <if test="settlementId != null">settlement_id = #{settlementId},</if>
            update_time = NOW()
        </set>
        WHERE ledger_id = #{ledgerId}
    </update>

    <delete id="deleteJstSalesCommissionLedgerByLedgerId" parameterType="Long">
        DELETE FROM jst_sales_commission_ledger WHERE ledger_id = #{ledgerId}
    </delete>

</mapper>
