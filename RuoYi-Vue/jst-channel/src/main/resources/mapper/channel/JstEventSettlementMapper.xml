            <if test="totalRefund != null "> and t.total_refund = #{totalRefund}</if>
            <if test="totalRebate != null "> and t.total_rebate = #{totalRebate}</if>
            <if test="totalServiceFee != null "> and t.total_service_fee = #{totalServiceFee}</if>
            <if test="contractDeduction != null "> and t.contract_deduction = #{contractDeduction}</if>
            <if test="finalAmount != null "> and t.final_amount = #{finalAmount}</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
            <if test="auditRemark != null  and auditRemark != ''"> and t.audit_remark = #{auditRemark}</if>
            <if test="payVoucherUrl != null  and payVoucherUrl != ''"> and t.pay_voucher_url = #{payVoucherUrl}</if>
            <if test="payTime != null "> and t.pay_time = #{payTime}</if>
        </where>
    </select>
    
    <select id="selectJstEventSettlementByEventSettlementId" parameterType="Long" resultMap="JstEventSettlementResult">
