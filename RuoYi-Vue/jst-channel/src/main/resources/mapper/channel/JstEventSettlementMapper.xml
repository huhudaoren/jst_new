    <sql id="selectJstEventSettlementVo">
        select t.*,
               ep.partner_name as partner_name_,
               ct.contest_name as contest_name_
        from jst_event_settlement t
        left join jst_event_partner ep on t.partner_id = ep.partner_id and ep.del_flag = '0'
        left join jst_contest ct on t.contest_id = ct.contest_id and ct.del_flag = '0'
    </sql>

    <select id="selectJstEventSettlementList" parameterType="JstEventSettlement" resultMap="JstEventSettlementResult">
        <include refid="selectJstEventSettlementVo"/>
        <where>
            <if test="settlementNo != null  and settlementNo != ''"> and t.settlement_no = #{settlementNo}</if>
            <if test="partnerId != null "> and t.partner_id = #{partnerId}</if>
            <if test="contestId != null "> and t.contest_id = #{contestId}</if>
