<!--        </dependency>-->

        <!-- 新写法（Spring Boot 4.0+） -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-aspectj</artifactId>
        </dependency>

        <!-- Web MVC: HandlerInterceptor / WebMvcConfigurer (登录上下文需要) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

</project>
