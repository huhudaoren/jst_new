    <modelVersion>4.0.0</modelVersion>

    <artifactId>jst-common</artifactId>

    <description>
        竞赛通-业务通用模块
        包含：业务异常码、业务枚举、雪花ID、Redisson 配置、阿里云 OSS 工具、统一加解密(AES)
        所有 jst-* 业务模块强制依赖此模块
    </description>

    <dependencies>
        <!-- 复用若依通用工具（含 Redis/Spring/MyBatis 基础） -->
        <dependency>
            <groupId>com.ruoyi</groupId>
            <artifactId>ruoyi-common</artifactId>
        </dependency>

        <!-- 分布式锁 Redisson -->
        <dependency>
            <groupId>org.redisson</groupId>
            <artifactId>redisson-spring-boot-starter</artifactId>
        </dependency>

        <!-- 阿里云 OSS 对象存储（图片/凭证/合同附件等） -->
        <dependency>
            <groupId>com.aliyun.oss</groupId>
            <artifactId>aliyun-sdk-oss</artifactId>
        </dependency>

<!--        &lt;!&ndash; AOP（@OperateLog / @PartnerScope / @ChannelScope 切面） &ndash;&gt;-->
