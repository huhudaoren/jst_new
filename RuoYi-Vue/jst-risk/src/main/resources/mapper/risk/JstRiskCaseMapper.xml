<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.risk.mapper.JstRiskCaseMapper">
    
    <resultMap type="JstRiskCase" id="JstRiskCaseResult">
        <result property="caseId"    column="case_id"    />
        <result property="caseNo"    column="case_no"    />
        <result property="alertId"    column="alert_id"    />
        <result property="assigneeId"    column="assignee_id"    />
        <result property="status"    column="status"    />
        <result property="conclusion"    column="conclusion"    />
        <result property="reviewerId"    column="reviewer_id"    />
        <result property="closeTime"    column="close_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstRiskCaseVo">
        select case_id, case_no, alert_id, assignee_id, status, conclusion, reviewer_id, close_time, create_by, create_time, update_by, update_time, remark, del_flag from jst_risk_case
    </sql>

    <select id="selectJstRiskCaseList" parameterType="JstRiskCase" resultMap="JstRiskCaseResult">
        <include refid="selectJstRiskCaseVo"/>
        <where>  
            <if test="caseNo != null  and caseNo != ''"> and case_no = #{caseNo}</if>
            <if test="alertId != null "> and alert_id = #{alertId}</if>
            <if test="assigneeId != null "> and assignee_id = #{assigneeId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="conclusion != null  and conclusion != ''"> and conclusion = #{conclusion}</if>
            <if test="reviewerId != null "> and reviewer_id = #{reviewerId}</if>
            <if test="closeTime != null "> and close_time = #{closeTime}</if>
        </where>
    </select>
    
    <select id="selectJstRiskCaseByCaseId" parameterType="Long" resultMap="JstRiskCaseResult">
        <include refid="selectJstRiskCaseVo"/>
        where case_id = #{caseId}
    </select>

    <insert id="insertJstRiskCase" parameterType="JstRiskCase" useGeneratedKeys="true" keyProperty="caseId">
        insert into jst_risk_case
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="caseNo != null and caseNo != ''">case_no,</if>
            <if test="alertId != null">alert_id,</if>
            <if test="assigneeId != null">assignee_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="conclusion != null">conclusion,</if>
            <if test="reviewerId != null">reviewer_id,</if>
            <if test="closeTime != null">close_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="caseNo != null and caseNo != ''">#{caseNo},</if>
            <if test="alertId != null">#{alertId},</if>
            <if test="assigneeId != null">#{assigneeId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="conclusion != null">#{conclusion},</if>
            <if test="reviewerId != null">#{reviewerId},</if>
            <if test="closeTime != null">#{closeTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstRiskCase" parameterType="JstRiskCase">
        update jst_risk_case
        <trim prefix="SET" suffixOverrides=",">
            <if test="caseNo != null and caseNo != ''">case_no = #{caseNo},</if>
            <if test="alertId != null">alert_id = #{alertId},</if>
            <if test="assigneeId != null">assignee_id = #{assigneeId},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="conclusion != null">conclusion = #{conclusion},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            <if test="closeTime != null">close_time = #{closeTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where case_id = #{caseId}
    </update>

    <delete id="deleteJstRiskCaseByCaseId" parameterType="Long">
        delete from jst_risk_case where case_id = #{caseId}
    </delete>

    <delete id="deleteJstRiskCaseByCaseIds" parameterType="String">
        delete from jst_risk_case where case_id in 
        <foreach item="caseId" collection="array" open="(" separator="," close=")">
            #{caseId}
        </foreach>
    </delete>
</mapper>