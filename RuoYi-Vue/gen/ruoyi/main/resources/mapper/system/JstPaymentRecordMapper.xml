"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JstPaymentRecordMapper">
    
    <resultMap type="JstPaymentRecord" id="JstPaymentRecordResult">
        <result property="paymentId"    column="payment_id"    />
        <result property="paymentNo"    column="payment_no"    />
        <result property="orderId"    column="order_id"    />
        <result property="payMethod"    column="pay_method"    />
        <result property="cashAmount"    column="cash_amount"    />
        <result property="pointsAmount"    column="points_amount"    />
        <result property="pointsUsed"    column="points_used"    />
        <result property="thirdPartyNo"    column="third_party_no"    />
        <result property="voucherUrl"    column="voucher_url"    />
        <result property="voucherAuditStatus"    column="voucher_audit_status"    />
        <result property="payStatus"    column="pay_status"    />
        <result property="payTime"    column="pay_time"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstPaymentRecordVo">
        select payment_id, payment_no, order_id, pay_method, cash_amount, points_amount, points_used, third_party_no, voucher_url, voucher_audit_status, pay_status, pay_time, operator_id, create_by, create_time, update_by, update_time, remark, del_flag from jst_payment_record
    </sql>

    <select id="selectJstPaymentRecordList" parameterType="JstPaymentRecord" resultMap="JstPaymentRecordResult">
        <include refid="selectJstPaymentRecordVo"/>
        <where>  
            <if test="paymentNo != null  and paymentNo != ''"> and payment_no = #{paymentNo}</if>
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="payMethod != null  and payMethod != ''"> and pay_method = #{payMethod}</if>
            <if test="cashAmount != null "> and cash_amount = #{cashAmount}</if>
            <if test="pointsAmount != null "> and points_amount = #{pointsAmount}</if>
            <if test="pointsUsed != null "> and points_used = #{pointsUsed}</if>
            <if test="thirdPartyNo != null  and thirdPartyNo != ''"> and third_party_no = #{thirdPartyNo}</if>
            <if test="voucherUrl != null  and voucherUrl != ''"> and voucher_url = #{voucherUrl}</if>
            <if test="voucherAuditStatus != null  and voucherAuditStatus != ''"> and voucher_audit_status = #{voucherAuditStatus}</if>
            <if test="payStatus != null  and payStatus != ''"> and pay_status = #{payStatus}</if>
            <if test="payTime != null "> and pay_time = #{payTime}</if>
            <if test="operatorId != null "> and operator_id = #{operatorId}</if>
        </where>
    </select>
    
    <select id="selectJstPaymentRecordByPaymentId" parameterType="Long" resultMap="JstPaymentRecordResult">
        <include refid="selectJstPaymentRecordVo"/>
        where payment_id = #{paymentId}
    </select>

    <insert id="insertJstPaymentRecord" parameterType="JstPaymentRecord" useGeneratedKeys="true" keyProperty="paymentId">
        insert into jst_payment_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">payment_no,</if>
            <if test="orderId != null">order_id,</if>
            <if test="payMethod != null and payMethod != ''">pay_method,</if>
            <if test="cashAmount != null">cash_amount,</if>
            <if test="pointsAmount != null">points_amount,</if>
            <if test="pointsUsed != null">points_used,</if>
            <if test="thirdPartyNo != null">third_party_no,</if>
            <if test="voucherUrl != null">voucher_url,</if>
            <if test="voucherAuditStatus != null">voucher_audit_status,</if>
            <if test="payStatus != null and payStatus != ''">pay_status,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">#{paymentNo},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="payMethod != null and payMethod != ''">#{payMethod},</if>
            <if test="cashAmount != null">#{cashAmount},</if>
            <if test="pointsAmount != null">#{pointsAmount},</if>
            <if test="pointsUsed != null">#{pointsUsed},</if>
            <if test="thirdPartyNo != null">#{thirdPartyNo},</if>
            <if test="voucherUrl != null">#{voucherUrl},</if>
            <if test="voucherAuditStatus != null">#{voucherAuditStatus},</if>
            <if test="payStatus != null and payStatus != ''">#{payStatus},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstPaymentRecord" parameterType="JstPaymentRecord">
        update jst_payment_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="paymentNo != null and paymentNo != ''">payment_no = #{paymentNo},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="payMethod != null and payMethod != ''">pay_method = #{payMethod},</if>
            <if test="cashAmount != null">cash_amount = #{cashAmount},</if>
            <if test="pointsAmount != null">points_amount = #{pointsAmount},</if>
            <if test="pointsUsed != null">points_used = #{pointsUsed},</if>
            <if test="thirdPartyNo != null">third_party_no = #{thirdPartyNo},</if>
            <if test="voucherUrl != null">voucher_url = #{voucherUrl},</if>
            <if test="voucherAuditStatus != null">voucher_audit_status = #{voucherAuditStatus},</if>
            <if test="payStatus != null and payStatus != ''">pay_status = #{payStatus},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="operatorId != null">operator_id = #{operatorId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where payment_id = #{paymentId}
    </update>

    <delete id="deleteJstPaymentRecordByPaymentId" parameterType="Long">
        delete from jst_payment_record where payment_id = #{paymentId}
    </delete>

    <delete id="deleteJstPaymentRecordByPaymentIds" parameterType="String">
        delete from jst_payment_record where payment_id in 
        <foreach item="paymentId" collection="array" open="(" separator="," close=")">
            #{paymentId}
        </foreach>
    </delete>
</mapper>