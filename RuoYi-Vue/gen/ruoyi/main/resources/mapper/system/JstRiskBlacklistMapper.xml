            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where list_id = #{listId}
    </update>

    <delete id="deleteJstRiskBlacklistByListId" parameterType="Long">
        delete from jst_risk_blacklist where list_id = #{listId}
    </delete>

    <delete id="deleteJstRiskBlacklistByListIds" parameterType="String">
        delete from jst_risk_blacklist where list_id in 
        <foreach item="listId" collection="array" open="(" separator="," close=")">
            #{listId}
        </foreach>
    </delete>
</mapper>