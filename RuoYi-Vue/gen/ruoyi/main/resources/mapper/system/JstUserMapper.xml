    <sql id="selectJstUserVo">
        select user_id, openid, unionid, mobile, nickname, avatar, real_name, gender, birthday, id_card_no, guardian_name, guardian_mobile, user_type, current_level_id, total_points, available_points, frozen_points, growth_value, bound_channel_id, status, risk_flag, register_time, last_login_time, create_by, create_time, update_by, update_time, remark, del_flag from jst_user
    </sql>

    <select id="selectJstUserList" parameterType="JstUser" resultMap="JstUserResult">
        <include refid="selectJstUserVo"/>
        <where>  
            <if test="openid != null  and openid != ''"> and openid = #{openid}</if>
            <if test="unionid != null  and unionid != ''"> and unionid = #{unionid}</if>
            <if test="mobile != null  and mobile != ''"> and mobile = #{mobile}</if>
            <if test="nickname != null  and nickname != ''"> and nickname like concat('%', #{nickname}, '%')</if>
            <if test="avatar != null  and avatar != ''"> and avatar = #{avatar}</if>
            <if test="realName != null  and realName != ''"> and real_name like concat('%', #{realName}, '%')</if>
            <if test="gender != null "> and gender = #{gender}</if>
            <if test="birthday != null "> and birthday = #{birthday}</if>
            <if test="idCardNo != null  and idCardNo != ''"> and id_card_no = #{idCardNo}</if>
            <if test="guardianName != null  and guardianName != ''"> and guardian_name like concat('%', #{guardianName}, '%')</if>
            <if test="guardianMobile != null  and guardianMobile != ''"> and guardian_mobile = #{guardianMobile}</if>
            <if test="userType != null  and userType != ''"> and user_type = #{userType}</if>
            <if test="currentLevelId != null "> and current_level_id = #{currentLevelId}</if>
            <if test="totalPoints != null "> and total_points = #{totalPoints}</if>
            <if test="availablePoints != null "> and available_points = #{availablePoints}</if>
            <if test="frozenPoints != null "> and frozen_points = #{frozenPoints}</if>
            <if test="growthValue != null "> and growth_value = #{growthValue}</if>
            <if test="boundChannelId != null "> and bound_channel_id = #{boundChannelId}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="riskFlag != null "> and risk_flag = #{riskFlag}</if>
            <if test="registerTime != null "> and register_time = #{registerTime}</if>
            <if test="lastLoginTime != null "> and last_login_time = #{lastLoginTime}</if>
        </where>
    </select>
    
    <select id="selectJstUserByUserId" parameterType="Long" resultMap="JstUserResult">
        <include refid="selectJstUserVo"/>
        where user_id = #{userId}
    </select>

