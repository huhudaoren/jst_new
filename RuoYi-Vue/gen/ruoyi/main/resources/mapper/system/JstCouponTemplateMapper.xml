<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JstCouponTemplateMapper">
    
    <resultMap type="JstCouponTemplate" id="JstCouponTemplateResult">
        <result property="couponTemplateId"    column="coupon_template_id"    />
        <result property="couponName"    column="coupon_name"    />
        <result property="couponType"    column="coupon_type"    />
        <result property="faceValue"    column="face_value"    />
        <result property="discountRate"    column="discount_rate"    />
        <result property="thresholdAmount"    column="threshold_amount"    />
        <result property="applicableRole"    column="applicable_role"    />
        <result property="applicableContestIds"    column="applicable_contest_ids"    />
        <result property="validDays"    column="valid_days"    />
        <result property="validStart"    column="valid_start"    />
        <result property="validEnd"    column="valid_end"    />
        <result property="stackRule"    column="stack_rule"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstCouponTemplateVo">
        select coupon_template_id, coupon_name, coupon_type, face_value, discount_rate, threshold_amount, applicable_role, applicable_contest_ids, valid_days, valid_start, valid_end, stack_rule, status, create_by, create_time, update_by, update_time, remark, del_flag from jst_coupon_template
    </sql>

    <select id="selectJstCouponTemplateList" parameterType="JstCouponTemplate" resultMap="JstCouponTemplateResult">
        <include refid="selectJstCouponTemplateVo"/>
        <where>  
            <if test="couponName != null  and couponName != ''"> and coupon_name like concat('%', #{couponName}, '%')</if>
            <if test="couponType != null  and couponType != ''"> and coupon_type = #{couponType}</if>
            <if test="faceValue != null "> and face_value = #{faceValue}</if>
            <if test="discountRate != null "> and discount_rate = #{discountRate}</if>
            <if test="thresholdAmount != null "> and threshold_amount = #{thresholdAmount}</if>
            <if test="applicableRole != null  and applicableRole != ''"> and applicable_role = #{applicableRole}</if>
            <if test="applicableContestIds != null  and applicableContestIds != ''"> and applicable_contest_ids = #{applicableContestIds}</if>
            <if test="validDays != null "> and valid_days = #{validDays}</if>
            <if test="validStart != null "> and valid_start = #{validStart}</if>
            <if test="validEnd != null "> and valid_end = #{validEnd}</if>
            <if test="stackRule != null  and stackRule != ''"> and stack_rule = #{stackRule}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstCouponTemplateByCouponTemplateId" parameterType="Long" resultMap="JstCouponTemplateResult">
        <include refid="selectJstCouponTemplateVo"/>
        where coupon_template_id = #{couponTemplateId}
    </select>

    <insert id="insertJstCouponTemplate" parameterType="JstCouponTemplate" useGeneratedKeys="true" keyProperty="couponTemplateId">
        insert into jst_coupon_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="couponName != null and couponName != ''">coupon_name,</if>
            <if test="couponType != null and couponType != ''">coupon_type,</if>
            <if test="faceValue != null">face_value,</if>
            <if test="discountRate != null">discount_rate,</if>
            <if test="thresholdAmount != null">threshold_amount,</if>
            <if test="applicableRole != null">applicable_role,</if>
            <if test="applicableContestIds != null">applicable_contest_ids,</if>
            <if test="validDays != null">valid_days,</if>
            <if test="validStart != null">valid_start,</if>
            <if test="validEnd != null">valid_end,</if>
            <if test="stackRule != null">stack_rule,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="couponName != null and couponName != ''">#{couponName},</if>
            <if test="couponType != null and couponType != ''">#{couponType},</if>
            <if test="faceValue != null">#{faceValue},</if>
            <if test="discountRate != null">#{discountRate},</if>
            <if test="thresholdAmount != null">#{thresholdAmount},</if>
            <if test="applicableRole != null">#{applicableRole},</if>
            <if test="applicableContestIds != null">#{applicableContestIds},</if>
            <if test="validDays != null">#{validDays},</if>
            <if test="validStart != null">#{validStart},</if>
            <if test="validEnd != null">#{validEnd},</if>
            <if test="stackRule != null">#{stackRule},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstCouponTemplate" parameterType="JstCouponTemplate">
        update jst_coupon_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="couponName != null and couponName != ''">coupon_name = #{couponName},</if>
            <if test="couponType != null and couponType != ''">coupon_type = #{couponType},</if>
            <if test="faceValue != null">face_value = #{faceValue},</if>
            <if test="discountRate != null">discount_rate = #{discountRate},</if>
            <if test="thresholdAmount != null">threshold_amount = #{thresholdAmount},</if>
            <if test="applicableRole != null">applicable_role = #{applicableRole},</if>
            <if test="applicableContestIds != null">applicable_contest_ids = #{applicableContestIds},</if>
            <if test="validDays != null">valid_days = #{validDays},</if>
            <if test="validStart != null">valid_start = #{validStart},</if>
            <if test="validEnd != null">valid_end = #{validEnd},</if>
            <if test="stackRule != null">stack_rule = #{stackRule},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where coupon_template_id = #{couponTemplateId}
    </update>

    <delete id="deleteJstCouponTemplateByCouponTemplateId" parameterType="Long">
        delete from jst_coupon_template where coupon_template_id = #{couponTemplateId}
    </delete>

    <delete id="deleteJstCouponTemplateByCouponTemplateIds" parameterType="String">
        delete from jst_coupon_template where coupon_template_id in 
        <foreach item="couponTemplateId" collection="array" open="(" separator="," close=")">
            #{couponTemplateId}
        </foreach>
    </delete>
</mapper>