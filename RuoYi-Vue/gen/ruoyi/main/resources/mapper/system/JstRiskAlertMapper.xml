<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JstRiskAlertMapper">
    
    <resultMap type="JstRiskAlert" id="JstRiskAlertResult">
        <result property="alertId"    column="alert_id"    />
        <result property="riskRuleId"    column="risk_rule_id"    />
        <result property="riskLevel"    column="risk_level"    />
        <result property="targetType"    column="target_type"    />
        <result property="targetId"    column="target_id"    />
        <result property="hitDetailJson"    column="hit_detail_json"    />
        <result property="status"    column="status"    />
        <result property="caseId"    column="case_id"    />
        <result property="alertTime"    column="alert_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstRiskAlertVo">
        select alert_id, risk_rule_id, risk_level, target_type, target_id, hit_detail_json, status, case_id, alert_time, create_by, create_time, update_by, update_time, remark, del_flag from jst_risk_alert
    </sql>

    <select id="selectJstRiskAlertList" parameterType="JstRiskAlert" resultMap="JstRiskAlertResult">
        <include refid="selectJstRiskAlertVo"/>
        <where>  
            <if test="riskRuleId != null "> and risk_rule_id = #{riskRuleId}</if>
            <if test="riskLevel != null  and riskLevel != ''"> and risk_level = #{riskLevel}</if>
            <if test="targetType != null  and targetType != ''"> and target_type = #{targetType}</if>
            <if test="targetId != null "> and target_id = #{targetId}</if>
            <if test="hitDetailJson != null  and hitDetailJson != ''"> and hit_detail_json = #{hitDetailJson}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="caseId != null "> and case_id = #{caseId}</if>
            <if test="alertTime != null "> and alert_time = #{alertTime}</if>
        </where>
    </select>
    
    <select id="selectJstRiskAlertByAlertId" parameterType="Long" resultMap="JstRiskAlertResult">
        <include refid="selectJstRiskAlertVo"/>
        where alert_id = #{alertId}
    </select>

    <insert id="insertJstRiskAlert" parameterType="JstRiskAlert" useGeneratedKeys="true" keyProperty="alertId">
        insert into jst_risk_alert
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="riskRuleId != null">risk_rule_id,</if>
            <if test="riskLevel != null and riskLevel != ''">risk_level,</if>
            <if test="targetType != null and targetType != ''">target_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="hitDetailJson != null">hit_detail_json,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="caseId != null">case_id,</if>
            <if test="alertTime != null">alert_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="riskRuleId != null">#{riskRuleId},</if>
            <if test="riskLevel != null and riskLevel != ''">#{riskLevel},</if>
            <if test="targetType != null and targetType != ''">#{targetType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="hitDetailJson != null">#{hitDetailJson},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="caseId != null">#{caseId},</if>
            <if test="alertTime != null">#{alertTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstRiskAlert" parameterType="JstRiskAlert">
        update jst_risk_alert
        <trim prefix="SET" suffixOverrides=",">
            <if test="riskRuleId != null">risk_rule_id = #{riskRuleId},</if>
            <if test="riskLevel != null and riskLevel != ''">risk_level = #{riskLevel},</if>
            <if test="targetType != null and targetType != ''">target_type = #{targetType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="hitDetailJson != null">hit_detail_json = #{hitDetailJson},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="caseId != null">case_id = #{caseId},</if>
            <if test="alertTime != null">alert_time = #{alertTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where alert_id = #{alertId}
    </update>

    <delete id="deleteJstRiskAlertByAlertId" parameterType="Long">
        delete from jst_risk_alert where alert_id = #{alertId}
    </delete>

    <delete id="deleteJstRiskAlertByAlertIds" parameterType="String">
        delete from jst_risk_alert where alert_id in 
        <foreach item="alertId" collection="array" open="(" separator="," close=")">
            #{alertId}
        </foreach>
    </delete>
</mapper>