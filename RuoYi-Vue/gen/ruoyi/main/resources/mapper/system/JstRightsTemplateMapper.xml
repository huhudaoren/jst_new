<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JstRightsTemplateMapper">
    
    <resultMap type="JstRightsTemplate" id="JstRightsTemplateResult">
        <result property="rightsTemplateId"    column="rights_template_id"    />
        <result property="rightsName"    column="rights_name"    />
        <result property="rightsType"    column="rights_type"    />
        <result property="quotaMode"    column="quota_mode"    />
        <result property="quotaValue"    column="quota_value"    />
        <result property="validDays"    column="valid_days"    />
        <result property="writeoffMode"    column="writeoff_mode"    />
        <result property="applicableRole"    column="applicable_role"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstRightsTemplateVo">
        select rights_template_id, rights_name, rights_type, quota_mode, quota_value, valid_days, writeoff_mode, applicable_role, status, create_by, create_time, update_by, update_time, remark, del_flag from jst_rights_template
    </sql>

    <select id="selectJstRightsTemplateList" parameterType="JstRightsTemplate" resultMap="JstRightsTemplateResult">
        <include refid="selectJstRightsTemplateVo"/>
        <where>  
            <if test="rightsName != null  and rightsName != ''"> and rights_name like concat('%', #{rightsName}, '%')</if>
            <if test="rightsType != null  and rightsType != ''"> and rights_type = #{rightsType}</if>
            <if test="quotaMode != null  and quotaMode != ''"> and quota_mode = #{quotaMode}</if>
            <if test="quotaValue != null "> and quota_value = #{quotaValue}</if>
            <if test="validDays != null "> and valid_days = #{validDays}</if>
            <if test="writeoffMode != null  and writeoffMode != ''"> and writeoff_mode = #{writeoffMode}</if>
            <if test="applicableRole != null  and applicableRole != ''"> and applicable_role = #{applicableRole}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstRightsTemplateByRightsTemplateId" parameterType="Long" resultMap="JstRightsTemplateResult">
        <include refid="selectJstRightsTemplateVo"/>
        where rights_template_id = #{rightsTemplateId}
    </select>

    <insert id="insertJstRightsTemplate" parameterType="JstRightsTemplate" useGeneratedKeys="true" keyProperty="rightsTemplateId">
        insert into jst_rights_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="rightsName != null and rightsName != ''">rights_name,</if>
            <if test="rightsType != null and rightsType != ''">rights_type,</if>
            <if test="quotaMode != null and quotaMode != ''">quota_mode,</if>
            <if test="quotaValue != null">quota_value,</if>
            <if test="validDays != null">valid_days,</if>
            <if test="writeoffMode != null and writeoffMode != ''">writeoff_mode,</if>
            <if test="applicableRole != null and applicableRole != ''">applicable_role,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="rightsName != null and rightsName != ''">#{rightsName},</if>
            <if test="rightsType != null and rightsType != ''">#{rightsType},</if>
            <if test="quotaMode != null and quotaMode != ''">#{quotaMode},</if>
            <if test="quotaValue != null">#{quotaValue},</if>
            <if test="validDays != null">#{validDays},</if>
            <if test="writeoffMode != null and writeoffMode != ''">#{writeoffMode},</if>
            <if test="applicableRole != null and applicableRole != ''">#{applicableRole},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstRightsTemplate" parameterType="JstRightsTemplate">
        update jst_rights_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="rightsName != null and rightsName != ''">rights_name = #{rightsName},</if>
            <if test="rightsType != null and rightsType != ''">rights_type = #{rightsType},</if>
            <if test="quotaMode != null and quotaMode != ''">quota_mode = #{quotaMode},</if>
            <if test="quotaValue != null">quota_value = #{quotaValue},</if>
            <if test="validDays != null">valid_days = #{validDays},</if>
            <if test="writeoffMode != null and writeoffMode != ''">writeoff_mode = #{writeoffMode},</if>
            <if test="applicableRole != null and applicableRole != ''">applicable_role = #{applicableRole},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where rights_template_id = #{rightsTemplateId}
    </update>

    <delete id="deleteJstRightsTemplateByRightsTemplateId" parameterType="Long">
        delete from jst_rights_template where rights_template_id = #{rightsTemplateId}
    </delete>

    <delete id="deleteJstRightsTemplateByRightsTemplateIds" parameterType="String">
        delete from jst_rights_template where rights_template_id in 
        <foreach item="rightsTemplateId" collection="array" open="(" separator="," close=")">
            #{rightsTemplateId}
        </foreach>
    </delete>
</mapper>