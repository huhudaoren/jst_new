            <if test="memberPersons != null "> and member_persons = #{memberPersons}</if>
            <if test="extraPersons != null "> and extra_persons = #{extraPersons}</if>
            <if test="extraListJson != null  and extraListJson != ''"> and extra_list_json = #{extraListJson}</if>
            <if test="writeoffPersons != null "> and writeoff_persons = #{writeoffPersons}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstTeamAppointmentByTeamAppointmentId" parameterType="Long" resultMap="JstTeamAppointmentResult">
