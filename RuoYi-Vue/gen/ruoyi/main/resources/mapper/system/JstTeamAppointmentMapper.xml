    <select id="selectJstTeamAppointmentList" parameterType="JstTeamAppointment" resultMap="JstTeamAppointmentResult">
        <include refid="selectJstTeamAppointmentVo"/>
        <where>  
            <if test="teamNo != null  and teamNo != ''"> and team_no = #{teamNo}</if>
            <if test="contestId != null "> and contest_id = #{contestId}</if>
            <if test="channelId != null "> and channel_id = #{channelId}</if>
            <if test="teamName != null  and teamName != ''"> and team_name like concat('%', #{teamName}, '%')</if>
            <if test="appointmentDate != null "> and appointment_date = #{appointmentDate}</if>
            <if test="sessionCode != null  and sessionCode != ''"> and session_code = #{sessionCode}</if>
