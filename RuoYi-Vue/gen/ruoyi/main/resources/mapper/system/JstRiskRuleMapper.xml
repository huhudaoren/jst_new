<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JstRiskRuleMapper">
    
    <resultMap type="JstRiskRule" id="JstRiskRuleResult">
        <result property="riskRuleId"    column="risk_rule_id"    />
        <result property="ruleName"    column="rule_name"    />
        <result property="ruleType"    column="rule_type"    />
        <result property="dimension"    column="dimension"    />
        <result property="thresholdJson"    column="threshold_json"    />
        <result property="action"    column="action"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJstRiskRuleVo">
        select risk_rule_id, rule_name, rule_type, dimension, threshold_json, action, status, create_by, create_time, update_by, update_time, remark, del_flag from jst_risk_rule
    </sql>

    <select id="selectJstRiskRuleList" parameterType="JstRiskRule" resultMap="JstRiskRuleResult">
        <include refid="selectJstRiskRuleVo"/>
        <where>  
            <if test="ruleName != null  and ruleName != ''"> and rule_name like concat('%', #{ruleName}, '%')</if>
            <if test="ruleType != null  and ruleType != ''"> and rule_type = #{ruleType}</if>
            <if test="dimension != null  and dimension != ''"> and dimension = #{dimension}</if>
            <if test="thresholdJson != null  and thresholdJson != ''"> and threshold_json = #{thresholdJson}</if>
            <if test="action != null  and action != ''"> and action = #{action}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstRiskRuleByRiskRuleId" parameterType="Long" resultMap="JstRiskRuleResult">
        <include refid="selectJstRiskRuleVo"/>
        where risk_rule_id = #{riskRuleId}
    </select>

    <insert id="insertJstRiskRule" parameterType="JstRiskRule" useGeneratedKeys="true" keyProperty="riskRuleId">
        insert into jst_risk_rule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name,</if>
            <if test="ruleType != null and ruleType != ''">rule_type,</if>
            <if test="dimension != null and dimension != ''">dimension,</if>
            <if test="thresholdJson != null and thresholdJson != ''">threshold_json,</if>
            <if test="action != null and action != ''">action,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">#{ruleName},</if>
            <if test="ruleType != null and ruleType != ''">#{ruleType},</if>
            <if test="dimension != null and dimension != ''">#{dimension},</if>
            <if test="thresholdJson != null and thresholdJson != ''">#{thresholdJson},</if>
            <if test="action != null and action != ''">#{action},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstRiskRule" parameterType="JstRiskRule">
        update jst_risk_rule
        <trim prefix="SET" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name = #{ruleName},</if>
            <if test="ruleType != null and ruleType != ''">rule_type = #{ruleType},</if>
            <if test="dimension != null and dimension != ''">dimension = #{dimension},</if>
            <if test="thresholdJson != null and thresholdJson != ''">threshold_json = #{thresholdJson},</if>
            <if test="action != null and action != ''">action = #{action},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where risk_rule_id = #{riskRuleId}
    </update>

    <delete id="deleteJstRiskRuleByRiskRuleId" parameterType="Long">
        delete from jst_risk_rule where risk_rule_id = #{riskRuleId}
    </delete>

    <delete id="deleteJstRiskRuleByRiskRuleIds" parameterType="String">
        delete from jst_risk_rule where risk_rule_id in 
        <foreach item="riskRuleId" collection="array" open="(" separator="," close=")">
            #{riskRuleId}
        </foreach>
    </delete>
</mapper>