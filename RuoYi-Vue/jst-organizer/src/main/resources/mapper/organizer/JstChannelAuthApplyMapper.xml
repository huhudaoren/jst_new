        </trim>
        where apply_id = #{applyId}
    </update>

    <delete id="deleteJstChannelAuthApplyByApplyId" parameterType="Long">
        delete from jst_channel_auth_apply where apply_id = #{applyId}
    </delete>

    <delete id="deleteJstChannelAuthApplyByApplyIds" parameterType="String">
        delete from jst_channel_auth_apply where apply_id in 
        <foreach item="applyId" collection="array" open="(" separator="," close=")">
            #{applyId}
        </foreach>
    </delete>
</mapper>