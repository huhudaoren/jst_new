<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.marketing.mapper.JstUserCouponMapper">
    
    <resultMap type="JstUserCoupon" id="JstUserCouponResult">
        <result property="userCouponId"    column="user_coupon_id"    />
        <result property="couponTemplateId"    column="coupon_template_id"    />
        <result property="userId"    column="user_id"    />
        <result property="issueBatchNo"    column="issue_batch_no"    />
        <result property="issueSource"    column="issue_source"    />
        <result property="status"    column="status"    />
        <result property="validStart"    column="valid_start"    />
        <result property="validEnd"    column="valid_end"    />
        <result property="orderId"    column="order_id"    />
        <result property="useTime"    column="use_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="userName"    column="user_name_"    />
        <result property="couponTemplateName"    column="coupon_name_"    />
        <result property="orderNo"    column="order_no_"    />
    </resultMap>

    <sql id="selectJstUserCouponVo">
        select t.*,
               u.nick_name as user_name_,
               ct.coupon_name as coupon_name_,
               o.order_no as order_no_
        from jst_user_coupon t
        left join sys_user u on t.user_id = u.user_id and u.del_flag = '0'
        left join jst_coupon_template ct on t.coupon_template_id = ct.coupon_template_id and ct.del_flag = '0'
        left join jst_order_main o on t.order_id = o.order_id and o.del_flag = '0'
    </sql>

    <select id="selectJstUserCouponList" parameterType="JstUserCoupon" resultMap="JstUserCouponResult">
        <include refid="selectJstUserCouponVo"/>
        <where>
            <if test="couponTemplateId != null "> and t.coupon_template_id = #{couponTemplateId}</if>
            <if test="userId != null "> and t.user_id = #{userId}</if>
            <if test="issueBatchNo != null  and issueBatchNo != ''"> and t.issue_batch_no = #{issueBatchNo}</if>
            <if test="issueSource != null  and issueSource != ''"> and t.issue_source = #{issueSource}</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
            <if test="validStart != null "> and t.valid_start = #{validStart}</if>
            <if test="validEnd != null "> and t.valid_end = #{validEnd}</if>
            <if test="orderId != null "> and t.order_id = #{orderId}</if>
            <if test="useTime != null "> and t.use_time = #{useTime}</if>
        </where>
    </select>
    
    <select id="selectJstUserCouponByUserCouponId" parameterType="Long" resultMap="JstUserCouponResult">
        <include refid="selectJstUserCouponVo"/>
        where t.user_coupon_id = #{userCouponId}
    </select>

    <insert id="insertJstUserCoupon" parameterType="JstUserCoupon" useGeneratedKeys="true" keyProperty="userCouponId">
        insert into jst_user_coupon
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="couponTemplateId != null">coupon_template_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="issueBatchNo != null">issue_batch_no,</if>
            <if test="issueSource != null and issueSource != ''">issue_source,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="validStart != null">valid_start,</if>
            <if test="validEnd != null">valid_end,</if>
            <if test="orderId != null">order_id,</if>
            <if test="useTime != null">use_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="couponTemplateId != null">#{couponTemplateId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="issueBatchNo != null">#{issueBatchNo},</if>
            <if test="issueSource != null and issueSource != ''">#{issueSource},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="validStart != null">#{validStart},</if>
            <if test="validEnd != null">#{validEnd},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="useTime != null">#{useTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstUserCoupon" parameterType="JstUserCoupon">
        update jst_user_coupon
        <trim prefix="SET" suffixOverrides=",">
            <if test="couponTemplateId != null">coupon_template_id = #{couponTemplateId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="issueBatchNo != null">issue_batch_no = #{issueBatchNo},</if>
            <if test="issueSource != null and issueSource != ''">issue_source = #{issueSource},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="validStart != null">valid_start = #{validStart},</if>
            <if test="validEnd != null">valid_end = #{validEnd},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="useTime != null">use_time = #{useTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where user_coupon_id = #{userCouponId}
    </update>

    <delete id="deleteJstUserCouponByUserCouponId" parameterType="Long">
        delete from jst_user_coupon where user_coupon_id = #{userCouponId}
    </delete>

    <delete id="deleteJstUserCouponByUserCouponIds" parameterType="String">
        delete from jst_user_coupon where user_coupon_id in 
        <foreach item="userCouponId" collection="array" open="(" separator="," close=")">
            #{userCouponId}
        </foreach>
    </delete>
</mapper>