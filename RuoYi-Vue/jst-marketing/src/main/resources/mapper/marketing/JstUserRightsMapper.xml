<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.marketing.mapper.JstUserRightsMapper">
    
    <resultMap type="JstUserRights" id="JstUserRightsResult">
        <result property="userRightsId"    column="user_rights_id"    />
        <result property="rightsTemplateId"    column="rights_template_id"    />
        <result property="ownerType"    column="owner_type"    />
        <result property="ownerId"    column="owner_id"    />
        <result property="sourceType"    column="source_type"    />
        <result property="sourceRefId"    column="source_ref_id"    />
        <result property="remainQuota"    column="remain_quota"    />
        <result property="validStart"    column="valid_start"    />
        <result property="validEnd"    column="valid_end"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="userName"    column="user_name_"    />
    </resultMap>

    <sql id="selectJstUserRightsVo">
        select t.*,
               u.nick_name as user_name_
        from jst_user_rights t
        left join sys_user u on t.owner_id = u.user_id and u.del_flag = '0'
    </sql>

    <select id="selectJstUserRightsList" parameterType="JstUserRights" resultMap="JstUserRightsResult">
        <include refid="selectJstUserRightsVo"/>
        <where>
            <if test="rightsTemplateId != null "> and t.rights_template_id = #{rightsTemplateId}</if>
            <if test="ownerType != null  and ownerType != ''"> and t.owner_type = #{ownerType}</if>
            <if test="ownerId != null "> and t.owner_id = #{ownerId}</if>
            <if test="sourceType != null  and sourceType != ''"> and t.source_type = #{sourceType}</if>
            <if test="sourceRefId != null "> and t.source_ref_id = #{sourceRefId}</if>
            <if test="remainQuota != null "> and t.remain_quota = #{remainQuota}</if>
            <if test="validStart != null "> and t.valid_start = #{validStart}</if>
            <if test="validEnd != null "> and t.valid_end = #{validEnd}</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJstUserRightsByUserRightsId" parameterType="Long" resultMap="JstUserRightsResult">
        <include refid="selectJstUserRightsVo"/>
        where t.user_rights_id = #{userRightsId}
    </select>

    <insert id="insertJstUserRights" parameterType="JstUserRights" useGeneratedKeys="true" keyProperty="userRightsId">
        insert into jst_user_rights
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="rightsTemplateId != null">rights_template_id,</if>
            <if test="ownerType != null and ownerType != ''">owner_type,</if>
            <if test="ownerId != null">owner_id,</if>
            <if test="sourceType != null and sourceType != ''">source_type,</if>
            <if test="sourceRefId != null">source_ref_id,</if>
            <if test="remainQuota != null">remain_quota,</if>
            <if test="validStart != null">valid_start,</if>
            <if test="validEnd != null">valid_end,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="rightsTemplateId != null">#{rightsTemplateId},</if>
            <if test="ownerType != null and ownerType != ''">#{ownerType},</if>
            <if test="ownerId != null">#{ownerId},</if>
            <if test="sourceType != null and sourceType != ''">#{sourceType},</if>
            <if test="sourceRefId != null">#{sourceRefId},</if>
            <if test="remainQuota != null">#{remainQuota},</if>
            <if test="validStart != null">#{validStart},</if>
            <if test="validEnd != null">#{validEnd},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJstUserRights" parameterType="JstUserRights">
        update jst_user_rights
        <trim prefix="SET" suffixOverrides=",">
            <if test="rightsTemplateId != null">rights_template_id = #{rightsTemplateId},</if>
            <if test="ownerType != null and ownerType != ''">owner_type = #{ownerType},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="sourceType != null and sourceType != ''">source_type = #{sourceType},</if>
            <if test="sourceRefId != null">source_ref_id = #{sourceRefId},</if>
            <if test="remainQuota != null">remain_quota = #{remainQuota},</if>
            <if test="validStart != null">valid_start = #{validStart},</if>
            <if test="validEnd != null">valid_end = #{validEnd},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where user_rights_id = #{userRightsId}
    </update>

    <delete id="deleteJstUserRightsByUserRightsId" parameterType="Long">
        delete from jst_user_rights where user_rights_id = #{userRightsId}
    </delete>

    <delete id="deleteJstUserRightsByUserRightsIds" parameterType="String">
        delete from jst_user_rights where user_rights_id in 
        <foreach item="userRightsId" collection="array" open="(" separator="," close=")">
            #{userRightsId}
        </foreach>
    </delete>
</mapper>