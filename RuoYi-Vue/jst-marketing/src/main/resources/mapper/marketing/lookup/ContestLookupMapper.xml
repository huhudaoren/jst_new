<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jst.marketing.mapper.lookup.ContestLookupMapper">

    <select id="selectContestNamesByIds" resultType="java.util.LinkedHashMap">
        select contest_id as contestId,
               contest_name as contestName
        from jst_contest
        where del_flag = '0'
          and contest_id in
        <foreach collection="contestIds" item="contestId" open="(" separator="," close=")">
            #{contestId}
        </foreach>
    </select>
</mapper>
