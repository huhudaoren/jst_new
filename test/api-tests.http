### F5-1. 公开提交赛事方入驻申请
POST {{baseUrl}}/jst/public/organizer/partner/apply
Content-Type: {{contentType}}

{
  "partnerName": "测试_艺术教育",
  "contactName": "测试_王老板",
  "contactMobile": "13800005555",
  "businessLicenseNo": "91110000XXXXXXX"
}

> {%
client.global.set("partner_apply_no", response.body.data.applyNo);
client.global.set("partner_apply_id", response.body.data.applyId);
client.test("F5-1 公开提交赛事方入驻申请", function() {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.code === 200, "业务码应为 200");
    client.assert(response.body.data.applyId !== null, "applyId 不能为空");
    client.assert(response.body.data.applyNo.startsWith("PA"), "applyNo 应以 PA 开头");
});
%}

### F5-2. 公开查询申请状态
GET {{baseUrl}}/jst/public/organizer/partner/apply/{{partner_apply_no}}/status

> {%
client.test("F5-2 公开查询申请状态", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(response.body.data.applyStatus === "pending", "新提交申请应为 pending");
});
%}

### F5-3. 重复提交应失败
POST {{baseUrl}}/jst/public/organizer/partner/apply
Content-Type: {{contentType}}

{
  "partnerName": "测试_重复",
  "contactName": "x",
  "contactMobile": "13800005555"
}

> {%
client.test("F5-3 重复提交应失败", function() {
    client.assert(response.body.code === 60003, "应返回重复申请错误码 60003");
});
%}

### F5-4. admin 审核通过创建账号
POST {{baseUrl}}/jst/organizer/partner/apply/{{partner_apply_id}}/approve
Content-Type: {{contentType}}
Authorization: Bearer {{admin_token}}

{
  "auditRemark": "材料齐全",
  "username": "partner_test_001",
  "email": "test@example.com"
}

> {%
client.global.set("partner_id", response.body.data.partnerId);
client.global.set("partner_user_id", response.body.data.userId);
client.test("F5-4 审核通过创建账号", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(response.body.data.partnerId !== null, "partnerId 不能为空");
    client.assert(response.body.data.userId !== null, "userId 不能为空");
});
%}

### F5-5. 重复 approve 应失败
POST {{baseUrl}}/jst/organizer/partner/apply/{{partner_apply_id}}/approve
Content-Type: {{contentType}}
Authorization: Bearer {{admin_token}}

{
  "auditRemark": "重复提交",
  "username": "partner_test_001",
  "email": "test@example.com"
}

> {%
client.test("F5-5 重复 approve 应失败", function() {
    client.assert(response.body.code === 60002, "应返回非法状态跃迁错误码 60002");
});
%}

