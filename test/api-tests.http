GET {{baseUrl}}/jst/wx/contest/categories

> {%
client.test("F7-7 分类统计成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(Array.isArray(response.body.data), "data 应为数组");
    client.assert(response.body.data.length >= 1, "至少应返回 1 个分类");
    var culture = response.body.data.find(item => item.code === "culture");
    client.assert(culture, "应包含 culture 分类");
    client.assert(culture.count >= 1, "culture 分类数量应至少为 1");
});
%}

