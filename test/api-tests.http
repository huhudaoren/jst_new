> {%
client.test("F8-5 小程序取模板成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(response.body.data.templateId === 8801, "应返回 fixture 模板 8801");
    client.assert(response.body.data.templateVersion === 1, "fixture 模板版本应为 1");
    client.assert(Array.isArray(response.body.data.schemaJson.fields), "schemaJson.fields 应为数组");
    client.assert(response.body.data.schemaJson.fields.length === 5, "应返回 5 个标准字段");
});
%}

