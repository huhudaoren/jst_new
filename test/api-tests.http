### F7-4 (wx) 查列表 应能看到 online 的
GET {{baseUrl}}/jst/wx/contest/list?category=culture

> {%
client.test("F7-4 在线列表成功", function() {
    client.assert(response.status === 200);
    client.assert(Array.isArray(response.body.rows), "rows 应为数组");
    var contestId = Number(client.global.get("f7_contest_id"));
    var found = response.body.rows.find(item => item.contestId === contestId);
    client.assert(found, "应能查到新上线赛事");
    client.assert(found.status === "enrolling", "上线且在报名期内应变为 enrolling");
});
%}

