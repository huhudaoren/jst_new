### F4-0. 重新登录测试用户 1001（绑定场景）
POST {{baseUrl}}/jst/wx/auth/login
Content-Type: {{contentType}}

{
  "code": "MOCK_1001"
}

> {%
client.global.set("auth_token", response.body.data.token);
client.test("F4 登录成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
});
%}

### F4-1. 查询我的绑定历史（初始应有 2001 的 active 绑定）
GET {{baseUrl}}/jst/wx/user/binding
Authorization: Bearer {{auth_token}}

> {%
client.test("F4-1 绑定列表成功", function() {
    client.assert(response.status === 200);
    client.assert(Array.isArray(response.body.data), "应返回绑定数组");
    var active = response.body.data.find(item => item.status === "active");
    client.assert(active, "应存在 active 绑定");
    client.assert(active.channelId === 2001, "初始 active 绑定应为 channel 2001");
});
%}

### F4-2. 切换绑定到 channel 2002
POST {{baseUrl}}/jst/wx/user/binding/switch
Content-Type: {{contentType}}
Authorization: Bearer {{auth_token}}

{
  "channelId": 2002
}

> {%
client.global.set("f4_binding_id", response.body.data.bindingId);
client.test("F4-2 切换绑定成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(response.body.data.channelId === 2002, "应切换到 channel 2002");
    client.assert(response.body.data.status === "active", "新绑定应为 active");
});
%}

### F4-3. 重复绑定同一渠道 2002（应失败）
POST {{baseUrl}}/jst/wx/user/binding/switch
Content-Type: {{contentType}}
Authorization: Bearer {{auth_token}}

{
  "channelId": 2002
}

> {%
client.test("F4-3 重复绑定应失败", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code !== 200, "重复绑定同一渠道必须失败");
});
%}

### F4-4. 管理后台查询绑定列表（筛 active）
GET {{baseUrl}}/jst/user/binding/list?userId=1001&status=active
Authorization: Bearer {{admin_token}}

> {%
client.test("F4-4 管理后台绑定列表", function() {
    client.assert(response.status === 200);
    client.assert(Array.isArray(response.body.rows), "rows 应为数组");
    client.assert(response.body.rows.length === 1, "active 绑定应只有 1 条");
    client.assert(response.body.rows[0].channelId === 2002, "active 绑定应为 channel 2002");
});
%}

