### F6-5. 审核后重新登录，角色应包含 jst_channel
POST {{baseUrl}}/jst/wx/auth/login
Content-Type: {{contentType}}

{
  "code": "MOCK_1001"
}

> {%
client.test("F6-5 重新登录后角色已升级", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(Array.isArray(response.body.data.roles), "roles 应为数组");
    client.assert(response.body.data.roles.includes("jst_channel"), "roles 应包含 jst_channel");
    client.assert(response.body.data.userInfo.userType === "parent", "jst_user.user_type 不应被改成 channel");
});
%}

