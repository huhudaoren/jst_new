### QT-0. admin 登录
POST {{baseUrl}}/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "admin123",
  "code": "1",
  "uuid": ""
}

> {%
client.global.set("qt_admin_token", response.body.token);
client.test("QT-0 admin 登录成功", function() {
  client.assert(response.status === 200);
  client.assert(response.body.code === 200);
});
%}

### QT-1. 查询 JST_TASK 任务并提取 4 个 jobId
GET {{baseUrl}}/monitor/job/list?jobGroup=JST_TASK&pageNum=1&pageSize=100
Authorization: Bearer {{qt_admin_token}}

> {%
client.test("QT-1 查询任务列表成功", function() {
  client.assert(response.status === 200);
  client.assert(Array.isArray(response.body.rows));
});
var rows = response.body.rows || [];
function findJobId(target) {
  for (var i = 0; i < rows.length; i++) {
    if (rows[i].invokeTarget === target) {
      return rows[i].jobId;
    }
  }
  return null;
}
client.global.set("qt_order_job_id", findJobId("orderTimeoutCancelTask.execute()"));
client.global.set("qt_refund_job_id", findJobId("refundTimeoutCloseTask.execute()"));
client.global.set("qt_rebate_job_id", findJobId("rebateAutoSettleTask.execute()"));
client.global.set("qt_appointment_job_id", findJobId("appointmentExpireTask.execute()"));
client.test("QT-1 四个任务均已注册", function() {
  client.assert(client.global.get("qt_order_job_id"));
  client.assert(client.global.get("qt_refund_job_id"));
  client.assert(client.global.get("qt_rebate_job_id"));
  client.assert(client.global.get("qt_appointment_job_id"));
});
%}

