Authorization: Bearer {{admin_token}}

### I4. admin 审核通过
POST {{baseUrl}}/jst/event/form/template/{{template_id}}/audit/approve
Content-Type: {{contentType}}
Authorization: Bearer {{admin_token}}

{ "auditRemark": "测试通过" }

### I5. 非法字段类型应被拒绝
POST {{baseUrl}}/jst/event/form/template/save
Content-Type: {{contentType}}
Authorization: Bearer {{admin_token}}

{
  "templateName": "测试_非法类型",
  "ownerType": "platform",
  "schemaJson": {
    "fields": [
      { "key": "x", "type": "unknown_type", "label": "非法", "required": true }
    ]
  }
}

> {%
client.test("非法字段类型应被拒绝", function() {
    client.assert(response.body.code !== 200);
});
%}


