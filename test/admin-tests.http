Content-Type: {{contentType}}
Authorization: Bearer {{partner_b_token}}

{
  "contestId": {{contest_id}},
  "contestName": "测试_越权修改",
  "category": "culture",
  "groupLevels": "小学组",
  "enrollStartTime": "2026-04-01 09:00:00",
  "enrollEndTime": "2026-05-01 18:00:00",
  "price": 88.00,
  "supportChannelEnroll": 1,
  "supportPointsDeduct": 0,
  "supportAppointment": 0,
  "aftersaleDays": 7
}

> {%
client.test("越权应失败", function() {
    client.assert(response.body.code !== 200);
});
%}


