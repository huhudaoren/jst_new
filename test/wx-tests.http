### =====================================================================
### A. 认证与资料 (jst-user / WxAuthController + WxUserController)
### =====================================================================

### A1. Mock 登录测试用户 1001 (fixture: 测试_张妈妈)
POST {{baseUrl}}/jst/wx/auth/login
Content-Type: {{contentType}}

{ "code": "MOCK_1001" }

> {%
client.global.set("wx_token", response.body.data.token);
client.test("登录成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 200);
    client.assert(response.body.data.userInfo.userId === 1001);
});
%}

### A2. 获取我的资料(脱敏)
GET {{baseUrl}}/jst/wx/user/profile
Authorization: Bearer {{wx_token}}

> {%
client.test("资料返回脱敏字段", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.userId === 1001);
    if (response.body.data.mobileMasked) {
        client.assert(response.body.data.mobileMasked.includes("****"), "手机号必须脱敏");
    }
});
%}

### A3. 更新昵称(白名单字段)
PUT {{baseUrl}}/jst/wx/user/profile
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{ "nickname": "测试_张妈妈_新昵称" }

### A3.1 更新生日(DEBT-2 白名单补齐)
PUT {{baseUrl}}/jst/wx/user/profile
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{ "birthday": "1988-05-20" }

> {%
client.test("A3.1 update birthday should succeed", function() {
    client.assert(response.body.code === 200);
});
%}

### A3.2 更新监护人手机号(DEBT-2 白名单补齐)
PUT {{baseUrl}}/jst/wx/user/profile
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{ "guardianMobile": "13800001234" }

> {%
client.test("A3.2 update guardianMobile should succeed", function() {
    client.assert(response.body.code === 200);
});
%}

### A3.3 再次获取资料验证回显(birthday + guardianMobileMasked)
GET {{baseUrl}}/jst/wx/user/profile
Authorization: Bearer {{wx_token}}

> {%
client.test("A3.3 profile should echo back birthday and masked guardianMobile", function() {
    client.assert(response.body.code === 200);
    client.assert(response.body.data.birthday != null);
    client.assert(response.body.data.guardianMobileMasked != null);
});
%}

### A3.4 错误的 guardianMobile 格式应被拒绝
PUT {{baseUrl}}/jst/wx/user/profile
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{ "guardianMobile": "12345" }

> {%
client.test("A3.4 invalid guardianMobile should fail", function() {
    client.assert(response.body.code !== 200);
});
%}

