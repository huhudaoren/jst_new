### C6-W7. my appointment detail should expose 3 writeoff qr items
GET {{baseUrl}}/jst/wx/appointment/{{c6_appt_1001}}
Authorization: Bearer {{c6_student_token}}

> {%
client.test("C6-W7 my appointment detail should expose qr items", function() {
    client.assert(response.body.code === 200);
    client.assert(Array.isArray(response.body.data.writeoffItems));
    client.assert(response.body.data.writeoffItems.length === 3);
    client.assert(response.body.data.writeoffItems.every(item => !!item.qrCode));
});
if (response.body.code === 200 && response.body.data && Array.isArray(response.body.data.writeoffItems)) {
    const parseWriteoffToken = function(payload) {
        if (typeof payload !== "string") {
            return payload;
        }
        const match = payload.match(/[?&]t=([^&]+)/);
        return match ? decodeURIComponent(match[1]) : payload;
    };
    const firstQr = response.body.data.writeoffItems[0].qrCode;
    const secondQr = response.body.data.writeoffItems[1].qrCode;
    const secondToken = parseWriteoffToken(secondQr);
    client.global.set("c6_writeoff_qr_raw_a", parseWriteoffToken(firstQr));
    client.global.set("c6_writeoff_qr_url_b", "http://127.0.0.1:8080/wx/writeoff?t=" + encodeURIComponent(secondToken));
}
%}

