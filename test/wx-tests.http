### =====================================================================
### 竞赛通 - 小程序端 (wx) + 公开接口 测试文件
### =====================================================================
### 用法: IntelliJ 打开本文件,顶部 ▶️ Run All Requests in File
### 前置:
###   1. 业务表已建,99-test-fixtures.sql 已导入
###   2. ruoyi-admin 启动在 8080
###   3. 96-grant-jst-partner-permissions.sql 已跑(影响部分跨视角验证)
### 特点:
###   - 所有数据来自 fixture 预置,不依赖 admin 临时创建
###   - 仅测 wx 视角 + 公开页接口
###   - admin 端测试在 admin-tests.http
### =====================================================================

@baseUrl = http://127.0.0.1:8080
@contentType = application/json
### =====================================================================
### F9. 报名记录与表单快照 (jst-event / WxEnrollController)
### 前置: fixture 中 8802 为 online+enrolling+formTemplateId=8801；8903 为补件中的报名记录
### =====================================================================

### F9-0. 重新登录 1001
POST {{baseUrl}}/jst/wx/auth/login
Content-Type: {{contentType}}

{ "code": "MOCK_1001" }

> {%
client.global.set("wx_token", response.body.data.token);
%}

### F9-1. 保存报名草稿
POST {{baseUrl}}/jst/wx/enroll/draft
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{
  "contestId": 8802,
  "participantId": 3004,
  "formData": {
    "name": "测试_张小红",
    "gender": "female",
    "age": 9,
    "school": "测试_第一小学"
  },
  "attachments": [
    "https://fixture.example.com/wx/f9-draft-work.pdf"
  ]
}

> {%
if (response.body.code === 200 && response.body.data) {
    client.global.set("f9_draft_enroll_id", response.body.data.enrollId);
}
client.test("F9 草稿保存成功", function() {
    client.assert(response.body.code === 200);
});
%}

### F9-2. 提交报名
POST {{baseUrl}}/jst/wx/enroll/submit
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{
  "enrollId": {{f9_draft_enroll_id}},
  "contestId": 8802,
  "participantId": 3004,
  "formData": {
    "name": "测试_张小红",
    "gender": "female",
    "age": 9,
    "school": "测试_第一小学"
  },
  "attachments": [
    "https://fixture.example.com/wx/f9-submit-work.pdf"
  ]
}

> {%
if (response.body.code === 200 && response.body.data) {
    client.global.set("f9_submit_enroll_id", response.body.data.enrollId);
}
client.test("F9 报名提交成功", function() {
    client.assert(response.body.code === 200);
});
%}

### F9-3. 查看我提交的报名详情
GET {{baseUrl}}/jst/wx/enroll/{{f9_submit_enroll_id}}
Authorization: Bearer {{wx_token}}

> {%
client.test("F9 报名详情返回快照", function() {
    client.assert(response.body.code === 200);
    client.assert(response.body.data.formSnapshotJson, "应返回 formSnapshotJson");
});
%}

### F9-4. 提交补件 (fixture 8903)
POST {{baseUrl}}/jst/wx/enroll/8903/supplement
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{
  "formData": {
    "name": "测试_张小红",
    "gender": "female",
    "age": 9,
    "school": "测试_第一小学"
  },
  "attachments": [
    "https://fixture.example.com/wx/f9-supplement-work-new.pdf"
  ],
  "supplementRemark": "已补充最新附件"
}

### F9-5. 重复 pending 报名应失败 (fixture 8901)
POST {{baseUrl}}/jst/wx/enroll/submit
Content-Type: {{contentType}}
Authorization: Bearer {{wx_token}}

{
  "contestId": 8201,
  "participantId": 3001,
  "formData": {
    "name": "测试_张小明",
    "gender": "male",
    "age": 8,
    "school": "测试_第一小学"
  },
  "attachments": [
    "https://fixture.example.com/wx/f9-duplicate.pdf"
  ]
}

> {%
client.test("F9 重复 pending 报名应失败", function() {
    client.assert(response.body.code !== 200);
});
%}

